# Integration Test Environment
# Copy to .env.local and update with actual values to run integration tests locally

# PostgreSQL (Docker)
DATABASE_URL="postgresql://postgres:test@localhost:5433/test"

# Supabase (can be mock values for local testing)
SUPABASE_URL="http://localhost:54321"
SUPABASE_ANON_KEY="test-anon-key"
SUPABASE_SERVICE_KEY="test-service-key"
SUPABASE_JWT_SECRET="test-jwt-secret-32-chars-minimum!!"

# Redis (Docker)
REDIS_URL="redis://localhost:6379"

# Optional: PawaPay (use sandbox credentials)
PAWAPAY_API_KEY="test-api-key"
PAWAPAY_BASE_URL="https://staging-api.pawapay.io"
PAWAPAY_WEBHOOK_SECRET="test-webhook-secret"
