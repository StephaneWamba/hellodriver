# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── Database (Supabase PostgreSQL + PostGIS) ──────────────────────────────────
# Use the -pooler endpoint in production (Transaction mode, port 6543)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres

# ─── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# ─── Redis (TCP — Railway or Redis Cloud, NOT Upstash) ─────────────────────────
# maxmemory-policy must be noeviction (BullMQ + Socket.io require it)
REDIS_URL=redis://default:[PASSWORD]@[HOST]:[PORT]

# ─── Anthropic (WhatsApp AI agent) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Meta / WhatsApp Cloud API ────────────────────────────────────────────────
META_VERIFY_TOKEN=your-webhook-verify-token
META_ACCESS_TOKEN=EAAxxxxxxx
META_PHONE_NUMBER_ID=1234567890

# ─── pawaPay (Gabon: Airtel Money + Moov Money) ───────────────────────────────
PAWAPAY_API_KEY=your-pawapay-api-key
PAWAPAY_WEBHOOK_SECRET=your-pawapay-webhook-secret
# Sandbox: https://api.sandbox.pawapay.io  |  Production: https://api.pawapay.io
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io

# ─── Mapbox ───────────────────────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=pk.eyJ1...

# ─── Africa's Talking (SMS fallback) ─────────────────────────────────────────
AT_API_KEY=your-at-api-key
AT_USERNAME=sandbox

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ─── BetterStack (Uptime) ─────────────────────────────────────────────────────
BETTERSTACK_SOURCE_TOKEN=your-betterstack-token
