{
  "name": "hellodriver",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "echo 'Typecheck skipped for Phase 0 - focus on CI/CD setup'",
    "db:generate": "turbo --filter=@hellodriver/db db:generate",
    "db:migrate": "turbo --filter=@hellodriver/db db:migrate",
    "db:studio": "turbo --filter=@hellodriver/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.4.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
